generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ USERS & AUTH ============

enum UserRole {
  ADMIN
  EMPLOYEE
  BRAND
  CREATOR
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  avatar        String?
  role          UserRole  @default(EMPLOYEE)
  brandName     String?   // Only for BRAND users
  isActive      Boolean   @default(true)

  // Creator profile fields (only for CREATOR role)
  creatorUsername    String?   // @handle
  creatorPlatform   String?   // INSTAGRAM, TIKTOK, YOUTUBE
  creatorBio        String?
  creatorCategory   String?   // lifestyle, beauty, tech, food, fitness, etc.
  portfolioUrl      String?   // Link to portfolio/media kit
  portfolioFiles    String[]  // URLs to uploaded portfolio files
  creatorFollowers  Int?
  creatorCountry    String?
  creatorCity       String?
  creatorLanguages  String[]
  creatorType       String?   // MACRO, MICRO, NANO, UGC
  isVerified        Boolean   @default(false)  // Admin-verified creator
  verifiedAt        DateTime?
  verifiedBy        String?   // Admin user ID who verified
  linkedInfluencerId String?  // Link to Influencer model if exists
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  campaigns     Campaign[]
  lists         List[]
  contacts      Contact[]
  invitations   Invitation[]
  assignedCampaigns CampaignAssignment[]
  socialTokens  SocialToken[]
  clientContacts    ClientContact[]
  clientCreatorMatches ClientCreatorMatch[]
  liveCaptureWidgets  LiveCaptureWidget[]

  @@map("users")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      UserRole @default(EMPLOYEE)
  token     String   @unique
  expiresAt DateTime
  accepted  Boolean  @default(false)

  invitedBy String
  user      User     @relation(fields: [invitedBy], references: [id])

  createdAt DateTime @default(now())

  @@map("invitations")
}

// ============ CAMPAIGNS ============

enum CampaignStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CampaignType {
  SOCIAL_LISTENING
  INFLUENCER_TRACKING
  UGC
}

enum Platform {
  INSTAGRAM
  TIKTOK
  YOUTUBE
}

model Campaign {
  id            String          @id @default(cuid())
  name          String
  status        CampaignStatus  @default(ACTIVE)
  type          CampaignType    @default(INFLUENCER_TRACKING)
  isPinned      Boolean         @default(false)
  startDate     DateTime        @default(now())
  endDate       DateTime?
  budget        Float?          @default(0)

  // Tracking targets
  targetAccounts String[]       // e.g. ["@vileda.es"]
  targetHashtags String[]       // e.g. ["#vileda"]
  targetKeywords String[]       // e.g. ["vileda"]
  platforms      Platform[]     @default([INSTAGRAM])
  country        String?        // Filter content by country (e.g. "ES", "MX")
  paymentType    String         @default("PAID") // "PAID" or "GIFTED"
  objective      String?        // Campaign objective: awareness, engagement, traffic, conversion, content

  // Manual ROI data (optional, entered by admin/employee, NOT used in automatic scoring)
  manualROI      Float?         // Manually entered ROI value (e.g. 2.5 = 2.5x return)
  manualROINotes String?        // Notes explaining the ROI (e.g. "Based on sales data from Q1")

  // Brief
  briefText      String?        // Campaign brief text
  briefFiles     String[]       // URLs/paths to brief attachments

  // Relations
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  influencers   CampaignInfluencer[]
  media         Media[]
  assignments   CampaignAssignment[]

  briefAttachments BriefFile[]

  shareToken    String?         @unique

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("campaigns")
}

// ============ BRIEF FILES ============

model BriefFile {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fileName   String
  fileType   String   // MIME type
  fileSize   Int      // bytes
  fileData   Bytes    // actual file content
  createdAt  DateTime @default(now())

  @@map("brief_files")
}

// ============ CAMPAIGN ASSIGNMENTS ============

model CampaignAssignment {
  id          String   @id @default(cuid())

  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([campaignId, userId])
  @@map("campaign_assignments")
}

// ============ INFLUENCERS / CREATORS ============

model Influencer {
  id            String    @id @default(cuid())
  username      String
  platform      Platform
  displayName   String?
  bio           String?
  avatarUrl     String?
  email         String?
  phone         String?
  website       String?

  // Metrics (updated periodically)
  followers     Int       @default(0)
  following     Int       @default(0)
  postsCount    Int       @default(0)
  engagementRate Float    @default(0)
  avgLikes      Int       @default(0)
  avgComments   Int       @default(0)
  avgViews      Int       @default(0)

  // Location & demographics
  country       String?
  city          String?
  language      String?
  gender        String?

  standardFee   Float?    // What the influencer typically charges

  isVerified    Boolean   @default(false)
  lastScraped   DateTime?
  dataSource    String?   // "api", "oauth", "marketplace", "apify"

  // Relations
  campaigns     CampaignInfluencer[]
  media         Media[]
  listItems     ListItem[]
  contactInfo   Contact[]
  socialTokens  SocialToken[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([username, platform])
  @@map("influencers")
}

enum InfluencerStatus {
  PROSPECT
  OUTREACH
  NEGOTIATING
  AGREED
  CONTRACTED
  SHIPPING
  POSTED
  COMPLETED
}

model CampaignInfluencer {
  id            String    @id @default(cuid())

  campaignId    String
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  influencerId  String
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  // Pipeline status
  status        InfluencerStatus @default(PROSPECT)

  // Per-campaign costs
  cost          Float?    @default(0)
  agreedFee     Float?    // What was agreed for THIS specific campaign
  commission    Float?    @default(0)
  notes         String?
  portfolioUrl  String?   // UGC creator portfolio link
  contentDelivered Boolean @default(false) // Whether UGC content has been delivered

  // Shipping / Fulfillment data
  shippingName     String?   // Recipient name
  shippingAddress1 String?   // Address line 1
  shippingAddress2 String?   // Address line 2
  shippingCity     String?
  shippingPostCode String?
  shippingCountry  String?
  shippingPhone    String?
  shippingEmail    String?
  shippingProduct  String?   // SKU or product name
  shippingQty      Int?      @default(1)
  shippingComments String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([campaignId, influencerId])
  @@map("campaign_influencers")
}

// ============ MEDIA (Posts, Stories, Reels, Videos) ============

enum MediaType {
  POST
  REEL
  STORY
  VIDEO
  SHORT
  CAROUSEL
}

model Media {
  id            String    @id @default(cuid())
  externalId    String?   // ID from the platform
  platform      Platform
  mediaType     MediaType

  // Content
  caption       String?
  mediaUrl      String?   // Direct URL to media
  thumbnailUrl  String?
  permalink     String?   // Link to original post

  // Metrics
  likes         Int       @default(0)
  comments      Int       @default(0)
  shares        Int       @default(0)
  saves         Int       @default(0)
  views         Int       @default(0)
  reach         Int       @default(0)
  impressions   Int       @default(0)
  engagementRate Float    @default(0)

  // Calculated values
  mediaValue    Float     @default(0)

  // Mentions & Hashtags found
  mentions      String[]
  hashtags      String[]

  // Compliance / Deletion tracking
  isDeleted         Boolean   @default(false)
  deletedAt         DateTime?
  isPaidPartnership Boolean   @default(false)
  isAdDisclosed     Boolean   @default(false)
  dataSource        String?   // "api", "oauth", "marketplace", "apify"

  // Tracking
  postedAt      DateTime?
  discoveredAt  DateTime  @default(now())

  // Relations
  influencerId  String
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  campaignId    String?
  campaign      Campaign?  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  commentsList  Comment[]

  @@unique([externalId, platform])
  @@map("media")
}

// ============ COMMENTS (Sentiment Analysis) ============

model Comment {
  id              String   @id @default(cuid())
  externalId      String
  platform        Platform
  text            String
  authorUsername  String
  authorAvatarUrl String?
  likes           Int      @default(0)
  replies         Int      @default(0)
  sentiment       String?  // 'positive', 'negative', 'neutral'
  sentimentScore  Float?   // -1 to 1
  postedAt        DateTime?
  mediaId         String
  media           Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@unique([externalId, platform])
  @@index([mediaId])
  @@index([sentiment])
  @@map("comments")
}

// ============ LISTS ============

model List {
  id            String    @id @default(cuid())
  name          String
  isPinned      Boolean   @default(false)
  isArchived    Boolean   @default(false)

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  items         ListItem[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("lists")
}

model ListItem {
  id            String    @id @default(cuid())

  listId        String
  list          List      @relation(fields: [listId], references: [id], onDelete: Cascade)

  influencerId  String
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  notes         String?

  createdAt     DateTime  @default(now())

  @@unique([listId, influencerId])
  @@map("list_items")
}

// ============ CONTACTS (CRM) ============

model Contact {
  id            String    @id @default(cuid())

  influencerId  String
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  status        String?   @default("new") // new, contacted, negotiating, confirmed, declined
  lastContacted DateTime?
  notes         String?
  tags          String[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([influencerId, userId])
  @@map("contacts")
}

// ============ CAMPAIGN NOTES ============

model CampaignNote {
  id            String    @id @default(cuid())

  campaignId    String
  influencerId  String

  userId        String
  userName      String    // Denormalized for display

  text          String

  createdAt     DateTime  @default(now())

  @@index([campaignId, influencerId])
  @@map("campaign_notes")
}

// ============ CAMPAIGN TEMPLATES ============

model CampaignTemplate {
  id            String    @id @default(cuid())
  name          String
  type          CampaignType @default(INFLUENCER_TRACKING)
  platforms     Platform[]  @default([INSTAGRAM])
  country       String?
  paymentType   String    @default("PAID")
  targetAccounts String[]
  targetHashtags String[]
  briefText     String?

  userId        String

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("campaign_templates")
}

// ============ NOTIFICATIONS ============

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // campaign_created, influencer_added, media_posted, status_changed, etc.
  title     String
  message   String
  link      String?  // URL to navigate to on click
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}

// ============ SETTINGS (Key-Value Store) ============

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}

// ============ SCRAPING JOBS ============

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ScrapeJob {
  id            String    @id @default(cuid())
  jobType       String    // "stories", "posts", "profile", "discovery"
  status        JobStatus @default(PENDING)
  platform      Platform

  // What to scrape
  targetUsername String?
  targetUrl     String?
  campaignId    String?

  // Results
  itemsFound    Int       @default(0)
  errorMessage  String?

  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@map("scrape_jobs")
}

// ============ COMPETITOR MONITORING ============

model CompetitorAccount {
  id          String   @id @default(cuid())
  username    String
  platform    Platform
  displayName String?
  avatarUrl   String?
  bio         String?
  followers   Int      @default(0)
  following   Int      @default(0)
  postsCount  Int      @default(0)
  engagementRate Float @default(0)
  avgLikes    Int      @default(0)
  avgComments Int      @default(0)
  avgViews    Int      @default(0)
  lastScraped DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       CompetitorPost[]

  @@unique([username, platform])
}

model CompetitorPost {
  id          String   @id @default(cuid())
  externalId  String
  platform    Platform
  caption     String?
  mediaUrl    String?
  thumbnailUrl String?
  permalink   String?
  mediaType   String   @default("POST")
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  views       Int      @default(0)
  hashtags    String[]
  mentions    String[]
  postedAt    DateTime?
  competitorId String
  competitor  CompetitorAccount @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([externalId, platform])
  @@index([competitorId])
}

// ============ DISCOVERY: CREATOR PROFILES ============

model CreatorProfile {
  id                String    @id @default(cuid())
  displayName       String?
  primaryPlatform   Platform

  // Spain Fit
  spainFitScore     Float?    // 0-100
  spainFitLevel     String?   // confirmed/probable/partial/hispanic_global/latam/unknown

  // Categories
  primaryCategory   String?
  categories        String[]

  // Language
  primaryLanguage   String?
  languages         String[]

  // Geography (inferred from signals)
  geoCity           String?
  geoProvince       String?
  geoCountry        String?
  geoConfidence     String    @default("unknown") // observed/inferred/unknown

  // Contact
  contactEmail      String?
  contactEmailSource String?  // bio/website/manual
  websiteUrl        String?

  // Scoring
  performanceScore  Float?    // 0-100
  riskLevel         String?   // low/medium/high
  dataQualityScore  Float?    // 0-100

  // Type classification
  creatorType       String?   // influencer/ugc_organic/ugc_ads/mixed

  // Status
  isVerifiedCreator Boolean   @default(false)
  isSuppressed      Boolean   @default(false)
  lastEnriched      DateTime?

  // Relations
  platformProfiles  CreatorPlatformProfile[]
  snapshots         CreatorSnapshot[]
  posts             CreatorPost[]
  brandMentions     CreatorBrandMention[]
  geoSignals        CreatorGeoSignal[]
  categorySignals   CreatorCategorySignal[]
  scores            CreatorScoreRecord[]
  suppressionRequest SuppressionRequest?
  clientMatches     ClientCreatorMatch[]
  warmScores        WarmCreatorScore[]
  socialTokens      SocialToken[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("creator_profiles")
}

model CreatorPlatformProfile {
  id              String    @id @default(cuid())
  creatorId       String
  creator         CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  platform        Platform
  username        String
  platformUserId  String?

  // Metrics
  followers       Int       @default(0)
  following       Int       @default(0)
  postsCount      Int       @default(0)
  engagementRate  Float     @default(0)
  avgViews        Int       @default(0)
  avgLikes        Int       @default(0)
  avgComments     Int       @default(0)
  medianViews     Int?      // More reliable than avg

  // Profile data
  bio             String?
  avatarUrl       String?
  isVerified      Boolean   @default(false)

  // Tracking
  lastScraped     DateTime?
  dataSource      String    @default("apify") // apify/api/manual
  scrapeCount     Int       @default(0)

  // Link to existing Influencer model
  influencerId    String?   // Link to legacy Influencer if exists

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([platform, username])
  @@index([creatorId])
  @@index([followers])
  @@map("creator_platform_profiles")
}

model CreatorSnapshot {
  id              String    @id @default(cuid())
  creatorId       String
  creator         CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  platform        Platform
  followers       Int
  engagementRate  Float?
  avgViews        Int?
  avgLikes        Int?
  medianViews     Int?
  capturedAt      DateTime  @default(now())
  source          String    @default("apify")

  @@index([creatorId, capturedAt])
  @@map("creator_snapshots")
}

model CreatorPost {
  id              String    @id @default(cuid())
  creatorId       String
  creator         CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  platform        Platform
  externalId      String?
  mediaType       String    @default("POST") // POST/REEL/STORY/VIDEO/SHORT/CAROUSEL
  caption         String?
  likes           Int       @default(0)
  comments        Int       @default(0)
  views           Int       @default(0)
  shares          Int       @default(0)
  saves           Int       @default(0)
  permalink       String?
  thumbnailUrl    String?
  postedAt        DateTime?
  capturedAt      DateTime  @default(now())
  hashtags        String[]
  mentions        String[]
  isBrandCollab   Boolean   @default(false)
  detectedBrand   String?
  source          String    @default("apify")

  @@unique([platform, externalId])
  @@index([creatorId])
  @@index([postedAt])
  @@map("creator_posts")
}

model CreatorBrandMention {
  id              String    @id @default(cuid())
  creatorId       String
  creator         CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  brandName       String
  platform        Platform
  postId          String?
  mentionType     String    // hashtag/tag/caption/bio
  confidence      Float     @default(0.5)
  detectedAt      DateTime  @default(now())

  @@index([creatorId])
  @@index([brandName])
  @@map("creator_brand_mentions")
}

model CreatorGeoSignal {
  id              String    @id @default(cuid())
  creatorId       String
  creator         CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  signalType      String    // bio_text/city_mention/timezone/hashtag/language/flag_emoji/posting_hours
  value           String
  confidence      Float     @default(0.5)
  source          String    @default("inferred")
  detectedAt      DateTime  @default(now())

  @@index([creatorId])
  @@map("creator_geo_signals")
}

model CreatorCategorySignal {
  id              String    @id @default(cuid())
  creatorId       String
  creator         CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  category        String
  confidence      Float     @default(0.5)
  source          String    @default("inferred") // bio_keywords/hashtags/brand_collabs/manual
  detectedAt      DateTime  @default(now())

  @@index([creatorId])
  @@index([category])
  @@map("creator_category_signals")
}

model CreatorScoreRecord {
  id              String    @id @default(cuid())
  creatorId       String
  creator         CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  scoreType       String    // spain_fit/performance/fee_recommendation/risk/brand_safety
  score           Float
  signal          String    // green/yellow/red
  explanation     String    // human-readable
  components      Json?     // breakdown
  isInferred      Boolean   @default(true)
  confidence      Float     @default(0.5)
  calculatedAt    DateTime  @default(now())

  @@index([creatorId, scoreType])
  @@map("creator_score_records")
}

// ============ DISCOVERY: CRAWL JOBS ============

model CrawlJob {
  id              String    @id @default(cuid())
  jobType         String    // profile_scrape/hashtag_discovery/refresh/enrichment/seed
  platform        Platform?
  target          String    // username/hashtag/url
  priority        Int       @default(5) // 1=highest, 10=lowest
  status          String    @default("pending") // pending/running/completed/failed/stale
  attempts        Int       @default(0)
  maxAttempts     Int       @default(3)
  result          Json?
  error           String?
  itemsFound      Int       @default(0)
  scheduledFor    DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([status, priority, scheduledFor])
  @@index([jobType, platform])
  @@map("crawl_jobs_v2")
}

// ============ DISCOVERY: DATA PROVENANCE ============

model DataProvenance {
  id              String    @id @default(cuid())
  entityType      String    // creator/post/score
  entityId        String
  field           String    // followers/geoCountry/category
  value           String
  source          String    // apify/youtube_api/manual/inferred
  method          String    // scrape/api_call/nlp/heuristic
  confidence      Float     @default(0.5)
  isInferred      Boolean   @default(false)
  capturedAt      DateTime  @default(now())

  @@index([entityType, entityId])
  @@map("data_provenance")
}

// ============ DISCOVERY: COMPLIANCE ============

model SuppressionRequest {
  id              String    @id @default(cuid())
  creatorId       String    @unique
  creator         CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  requestType     String    // deletion/opposition/rectification
  requestedAt     DateTime  @default(now())
  processedAt     DateTime?
  status          String    @default("pending") // pending/processed/rejected
  reason          String?
  requestedBy     String?   // email of requester

  @@map("suppression_requests")
}

// ============ DISCOVERY: SPAIN CATEGORIES ============

model SpainCategory {
  id              String    @id @default(cuid())
  slug            String    @unique
  nameEs          String
  nameEn          String
  parentSlug      String?
  keywords        String[]  // for automatic detection
  hashtagsEs      String[]  // Spanish hashtags for this category
  brandsEs        String[]  // Spanish brands in this sector

  @@map("spain_categories")
}

// ============ CLIENT-CREATOR MATCHING (Warm Opportunities) ============

enum ClientContactSource {
  CSV_IMPORT
  CRM_HUBSPOT
  CRM_APOLLO
  MANUAL
  API
}

enum RelationshipType {
  CUSTOMER
  LEAD
  VENDOR
  PARTNER
  PAST_CUSTOMER
  EMPLOYEE
  OTHER
}

enum RelationshipStatus {
  ACTIVE
  INACTIVE
  CHURNED
}

enum MatchConfidenceLevel {
  EXACT
  PROBABLE
  POSSIBLE
  REJECTED
}

enum MatchStatus {
  AUTO_DETECTED
  USER_CONFIRMED
  USER_REJECTED
  PENDING_REVIEW
}

enum WarmOpportunityGrade {
  A
  B
  C
  D
  F
}

enum ExpectedResponseRate {
  VERY_HIGH
  HIGH
  MEDIUM
  LOW
}

model ClientContact {
  id                    String              @id @default(cuid())
  userId                String
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  source                ClientContactSource @default(MANUAL)
  externalCrmId         String?
  contactName           String
  contactEmail          String?
  companyName           String?
  companyDomain         String?
  socialHandles         Json?               // {"instagram": "xx", "tiktok": "yy"}
  phone                 String?
  tags                  String[]
  relationshipType      RelationshipType    @default(CUSTOMER)
  relationshipStatus    RelationshipStatus  @default(ACTIVE)
  lastActivityAt        DateTime?
  notes                 String?
  importBatchId         String?             // Group imports by batch

  matches               ClientCreatorMatch[]

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([userId])
  @@index([contactEmail])
  @@index([companyDomain])
  @@index([importBatchId])
  @@map("client_contacts")
}

model ClientCreatorMatch {
  id                    String                @id @default(cuid())
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  clientContactId       String
  clientContact         ClientContact         @relation(fields: [clientContactId], references: [id], onDelete: Cascade)

  creatorProfileId      String
  creatorProfile        CreatorProfile        @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  confidenceScore       Float                 @default(0)
  confidenceLevel       MatchConfidenceLevel  @default(POSSIBLE)
  matchSignals          Json?                 // ["email_exact", "domain_match", "name_company"]
  matchStatus           MatchStatus           @default(AUTO_DETECTED)

  reviewedBy            String?
  reviewedAt            DateTime?

  warmScore             WarmCreatorScore?

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@unique([clientContactId, creatorProfileId])
  @@index([userId])
  @@index([creatorProfileId])
  @@index([confidenceLevel])
  @@index([matchStatus])
  @@map("client_creator_matches")
}

model WarmCreatorScore {
  id                      String                @id @default(cuid())
  userId                  String

  matchId                 String                @unique
  match                   ClientCreatorMatch    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  creatorProfileId        String
  creatorProfile          CreatorProfile        @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  opportunityScore        Float                 @default(0)    // 0-100
  opportunityGrade        WarmOpportunityGrade  @default(F)
  opportunityReasons      Json?                 // ["active_client", "consistent_content", ...]
  riskFlags               Json?                 // ["low_engagement", "brand_conflict", ...]
  recommendedUse          String[]              // ["ugc_organic", "influencer", "ugc_ads", "not_recommended"]
  brandFitScore           Float                 @default(0)    // 0-100
  easeOfActivation        Float                 @default(0)    // 0-100
  expectedResponseRate    ExpectedResponseRate  @default(MEDIUM)

  scoredAt                DateTime              @default(now())
  scoringVersion          String                @default("1.0")

  @@index([userId])
  @@index([creatorProfileId])
  @@index([opportunityGrade])
  @@map("warm_creator_scores")
}

// ============ SOCIAL API TOKENS ============

model SocialToken {
  id             String    @id @default(cuid())
  platform       Platform
  tokenType      String    @default("page")  // "page", "user", "api_key", "brand", "creator"

  // For brand/platform tokens (Meta Page tokens, YouTube API keys)
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // For influencer tokens (YouTube Analytics OAuth)
  influencerId   String?
  influencer     Influencer? @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  // For creator-facing OAuth (public creator connect flow)
  creatorProfileId String?
  creatorProfile CreatorProfile? @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  // Token data (encrypted AES-256-GCM)
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?
  scopes         String[]

  // Platform-specific IDs
  platformUserId String?   // Meta: IG User ID, YouTube: Channel ID
  platformPageId String?   // Meta: Facebook Page ID

  isValid        Boolean   @default(true)
  lastUsedAt     DateTime?
  lastError      String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Meta-specific relations (Phase 2 OAuth)
  accountSnapshots   MetaAccountSnapshot[]
  media              MetaMedia[]
  audienceInsights   MetaAudienceInsight[]
  storyMentions      MetaStoryMention[]

  // Uniqueness is enforced in app code because (platform, userId, tokenType)
  // can conflict with (platform, creatorProfileId, tokenType) scenarios.
  @@index([platform, userId])
  @@index([platform, creatorProfileId])
  @@index([platform, influencerId])
  @@index([influencerId])
  @@map("social_tokens")
}

// ============ META (Instagram Business) — Phase 2 OAuth ============

model MetaAccountSnapshot {
  id              String   @id @default(cuid())
  socialTokenId   String
  socialToken     SocialToken @relation(fields: [socialTokenId], references: [id], onDelete: Cascade)
  igUsername      String
  igName          String?
  igBiography     String?
  igWebsite       String?
  igProfilePicUrl String?
  followersCount  Int
  followsCount    Int
  mediaCount      Int
  capturedAt      DateTime @default(now())

  @@index([socialTokenId])
  @@map("meta_account_snapshots")
}

model MetaMedia {
  id                String   @id @default(cuid())
  socialTokenId     String
  socialToken       SocialToken @relation(fields: [socialTokenId], references: [id], onDelete: Cascade)
  igMediaId         String
  mediaType         String
  caption           String?
  permalink         String?
  thumbnailUrl      String?
  mediaUrl          String?
  postedAt          DateTime?
  likeCount         Int      @default(0)
  commentsCount     Int      @default(0)
  reach             Int?
  impressions       Int?
  engagement        Int?
  saved             Int?
  shares            Int?
  storyExits        Int?
  storyReplies      Int?
  storyTapsForward  Int?
  storyTapsBack     Int?
  lastSyncedAt      DateTime @default(now())

  @@unique([socialTokenId, igMediaId])
  @@index([socialTokenId, mediaType])
  @@map("meta_media")
}

model MetaAudienceInsight {
  id              String   @id @default(cuid())
  socialTokenId   String
  socialToken     SocialToken @relation(fields: [socialTokenId], references: [id], onDelete: Cascade)
  genderAge       Json
  country         Json
  city            Json
  locale          Json
  onlineFollowers Json
  capturedAt      DateTime @default(now())

  @@index([socialTokenId])
  @@map("meta_audience_insights")
}

model MetaStoryMention {
  id               String   @id @default(cuid())
  socialTokenId    String
  socialToken      SocialToken @relation(fields: [socialTokenId], references: [id], onDelete: Cascade)
  mentionMediaId   String
  mentionUsername  String
  mentionedAt      DateTime
  matchedCreatorId String?
  capturedAt       DateTime @default(now())

  @@unique([socialTokenId, mentionMediaId])
  @@index([socialTokenId])
  @@index([matchedCreatorId])
  @@map("meta_story_mentions")
}

// ============ LIVE CAPTURE (Widget-based social handle capture) ============

model LiveCaptureWidget {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String    @default("Default Widget")
  apiKey          String    @unique @default(cuid())

  // Customization
  brandName       String?
  brandLogo       String?
  primaryColor    String    @default("#7c3aed")
  incentiveText   String?
  headlineText    String    @default("Share your social media")
  subtitleText    String?   @default("Connect with us and get exclusive offers")

  // Behavior
  triggerType     String    @default("exit_intent")
  triggerDelay    Int       @default(5)
  triggerScroll   Int       @default(50)
  showOnMobile    Boolean   @default(true)

  // Domains allowed
  allowedDomains  String[]

  // Stats
  impressions     Int       @default(0)
  submissions     Int       @default(0)

  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  captures        LiveCapture[]

  @@index([userId])
  @@index([apiKey])
  @@map("live_capture_widgets")
}

model LiveCapture {
  id              String    @id @default(cuid())
  widgetId        String
  widget          LiveCaptureWidget @relation(fields: [widgetId], references: [id], onDelete: Cascade)

  // Captured data
  instagramHandle String?
  tiktokHandle    String?
  youtubeHandle   String?
  email           String?
  name            String?

  // Visitor context
  pageUrl         String?
  referrer        String?
  userAgent       String?
  ipCountry       String?

  // Processing
  isProcessed     Boolean   @default(false)
  matchedContactId String?

  createdAt       DateTime  @default(now())

  @@index([widgetId])
  @@index([isProcessed])
  @@map("live_captures")
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ USERS & AUTH ============

enum UserRole {
  ADMIN
  EMPLOYEE
  BRAND
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  avatar        String?
  role          UserRole  @default(EMPLOYEE)
  brandName     String?   // Only for BRAND users
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  campaigns     Campaign[]
  lists         List[]
  contacts      Contact[]
  invitations   Invitation[]
  assignedCampaigns CampaignAssignment[]
  socialTokens  SocialToken[]

  @@map("users")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      UserRole @default(EMPLOYEE)
  token     String   @unique
  expiresAt DateTime
  accepted  Boolean  @default(false)

  invitedBy String
  user      User     @relation(fields: [invitedBy], references: [id])

  createdAt DateTime @default(now())

  @@map("invitations")
}

// ============ CAMPAIGNS ============

enum CampaignStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CampaignType {
  SOCIAL_LISTENING
  INFLUENCER_TRACKING
  UGC
}

enum Platform {
  INSTAGRAM
  TIKTOK
  YOUTUBE
}

model Campaign {
  id            String          @id @default(cuid())
  name          String
  status        CampaignStatus  @default(ACTIVE)
  type          CampaignType    @default(INFLUENCER_TRACKING)
  isPinned      Boolean         @default(false)
  startDate     DateTime        @default(now())
  endDate       DateTime?
  budget        Float?          @default(0)

  // Tracking targets
  targetAccounts String[]       // e.g. ["@vileda.es"]
  targetHashtags String[]       // e.g. ["#vileda"]
  targetKeywords String[]       // e.g. ["vileda"]
  platforms      Platform[]     @default([INSTAGRAM])
  country        String?        // Filter content by country (e.g. "ES", "MX")
  paymentType    String         @default("PAID") // "PAID" or "GIFTED"
  objective      String?        // Campaign objective: awareness, engagement, traffic, conversion, content

  // Brief
  briefText      String?        // Campaign brief text
  briefFiles     String[]       // URLs/paths to brief attachments

  // Relations
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  influencers   CampaignInfluencer[]
  media         Media[]
  assignments   CampaignAssignment[]

  briefAttachments BriefFile[]

  shareToken    String?         @unique

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("campaigns")
}

// ============ BRIEF FILES ============

model BriefFile {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fileName   String
  fileType   String   // MIME type
  fileSize   Int      // bytes
  fileData   Bytes    // actual file content
  createdAt  DateTime @default(now())

  @@map("brief_files")
}

// ============ CAMPAIGN ASSIGNMENTS ============

model CampaignAssignment {
  id          String   @id @default(cuid())

  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([campaignId, userId])
  @@map("campaign_assignments")
}

// ============ INFLUENCERS / CREATORS ============

model Influencer {
  id            String    @id @default(cuid())
  username      String
  platform      Platform
  displayName   String?
  bio           String?
  avatarUrl     String?
  email         String?
  phone         String?
  website       String?

  // Metrics (updated periodically)
  followers     Int       @default(0)
  following     Int       @default(0)
  postsCount    Int       @default(0)
  engagementRate Float    @default(0)
  avgLikes      Int       @default(0)
  avgComments   Int       @default(0)
  avgViews      Int       @default(0)

  // Location & demographics
  country       String?
  city          String?
  language      String?
  gender        String?

  standardFee   Float?    // What the influencer typically charges

  isVerified    Boolean   @default(false)
  lastScraped   DateTime?
  dataSource    String?   // "api", "oauth", "marketplace", "apify"

  // Relations
  campaigns     CampaignInfluencer[]
  media         Media[]
  listItems     ListItem[]
  contactInfo   Contact[]
  socialTokens  SocialToken[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([username, platform])
  @@map("influencers")
}

enum InfluencerStatus {
  PROSPECT
  OUTREACH
  NEGOTIATING
  AGREED
  CONTRACTED
  SHIPPING
  POSTED
  COMPLETED
}

model CampaignInfluencer {
  id            String    @id @default(cuid())

  campaignId    String
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  influencerId  String
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  // Pipeline status
  status        InfluencerStatus @default(PROSPECT)

  // Per-campaign costs
  cost          Float?    @default(0)
  agreedFee     Float?    // What was agreed for THIS specific campaign
  commission    Float?    @default(0)
  notes         String?
  portfolioUrl  String?   // UGC creator portfolio link
  contentDelivered Boolean @default(false) // Whether UGC content has been delivered

  // Shipping / Fulfillment data
  shippingName     String?   // Recipient name
  shippingAddress1 String?   // Address line 1
  shippingAddress2 String?   // Address line 2
  shippingCity     String?
  shippingPostCode String?
  shippingCountry  String?
  shippingPhone    String?
  shippingEmail    String?
  shippingProduct  String?   // SKU or product name
  shippingQty      Int?      @default(1)
  shippingComments String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([campaignId, influencerId])
  @@map("campaign_influencers")
}

// ============ MEDIA (Posts, Stories, Reels, Videos) ============

enum MediaType {
  POST
  REEL
  STORY
  VIDEO
  SHORT
  CAROUSEL
}

model Media {
  id            String    @id @default(cuid())
  externalId    String?   // ID from the platform
  platform      Platform
  mediaType     MediaType

  // Content
  caption       String?
  mediaUrl      String?   // Direct URL to media
  thumbnailUrl  String?
  permalink     String?   // Link to original post

  // Metrics
  likes         Int       @default(0)
  comments      Int       @default(0)
  shares        Int       @default(0)
  saves         Int       @default(0)
  views         Int       @default(0)
  reach         Int       @default(0)
  impressions   Int       @default(0)
  engagementRate Float    @default(0)

  // Calculated values
  mediaValue    Float     @default(0)

  // Mentions & Hashtags found
  mentions      String[]
  hashtags      String[]

  // Compliance / Deletion tracking
  isDeleted         Boolean   @default(false)
  deletedAt         DateTime?
  isPaidPartnership Boolean   @default(false)
  isAdDisclosed     Boolean   @default(false)
  dataSource        String?   // "api", "oauth", "marketplace", "apify"

  // Tracking
  postedAt      DateTime?
  discoveredAt  DateTime  @default(now())

  // Relations
  influencerId  String
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  campaignId    String?
  campaign      Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  commentsList  Comment[]

  @@unique([externalId, platform])
  @@map("media")
}

// ============ COMMENTS (Sentiment Analysis) ============

model Comment {
  id              String   @id @default(cuid())
  externalId      String
  platform        Platform
  text            String
  authorUsername  String
  authorAvatarUrl String?
  likes           Int      @default(0)
  replies         Int      @default(0)
  sentiment       String?  // 'positive', 'negative', 'neutral'
  sentimentScore  Float?   // -1 to 1
  postedAt        DateTime?
  mediaId         String
  media           Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@unique([externalId, platform])
  @@index([mediaId])
  @@index([sentiment])
  @@map("comments")
}

// ============ LISTS ============

model List {
  id            String    @id @default(cuid())
  name          String
  isPinned      Boolean   @default(false)
  isArchived    Boolean   @default(false)

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  items         ListItem[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("lists")
}

model ListItem {
  id            String    @id @default(cuid())

  listId        String
  list          List      @relation(fields: [listId], references: [id], onDelete: Cascade)

  influencerId  String
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  notes         String?

  createdAt     DateTime  @default(now())

  @@unique([listId, influencerId])
  @@map("list_items")
}

// ============ CONTACTS (CRM) ============

model Contact {
  id            String    @id @default(cuid())

  influencerId  String
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  status        String?   @default("new") // new, contacted, negotiating, confirmed, declined
  lastContacted DateTime?
  notes         String?
  tags          String[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([influencerId, userId])
  @@map("contacts")
}

// ============ CAMPAIGN NOTES ============

model CampaignNote {
  id            String    @id @default(cuid())

  campaignId    String
  influencerId  String

  userId        String
  userName      String    // Denormalized for display

  text          String

  createdAt     DateTime  @default(now())

  @@index([campaignId, influencerId])
  @@map("campaign_notes")
}

// ============ CAMPAIGN TEMPLATES ============

model CampaignTemplate {
  id            String    @id @default(cuid())
  name          String
  type          CampaignType @default(INFLUENCER_TRACKING)
  platforms     Platform[]  @default([INSTAGRAM])
  country       String?
  paymentType   String    @default("PAID")
  targetAccounts String[]
  targetHashtags String[]
  briefText     String?

  userId        String

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("campaign_templates")
}

// ============ NOTIFICATIONS ============

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // campaign_created, influencer_added, media_posted, status_changed, etc.
  title     String
  message   String
  link      String?  // URL to navigate to on click
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}

// ============ SETTINGS (Key-Value Store) ============

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}

// ============ SCRAPING JOBS ============

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ScrapeJob {
  id            String    @id @default(cuid())
  jobType       String    // "stories", "posts", "profile", "discovery"
  status        JobStatus @default(PENDING)
  platform      Platform

  // What to scrape
  targetUsername String?
  targetUrl     String?
  campaignId    String?

  // Results
  itemsFound    Int       @default(0)
  errorMessage  String?

  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@map("scrape_jobs")
}

// ============ COMPETITOR MONITORING ============

model CompetitorAccount {
  id          String   @id @default(cuid())
  username    String
  platform    Platform
  displayName String?
  avatarUrl   String?
  bio         String?
  followers   Int      @default(0)
  following   Int      @default(0)
  postsCount  Int      @default(0)
  engagementRate Float @default(0)
  avgLikes    Int      @default(0)
  avgComments Int      @default(0)
  avgViews    Int      @default(0)
  lastScraped DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       CompetitorPost[]

  @@unique([username, platform])
}

model CompetitorPost {
  id          String   @id @default(cuid())
  externalId  String
  platform    Platform
  caption     String?
  mediaUrl    String?
  thumbnailUrl String?
  permalink   String?
  mediaType   String   @default("POST")
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  views       Int      @default(0)
  hashtags    String[]
  mentions    String[]
  postedAt    DateTime?
  competitorId String
  competitor  CompetitorAccount @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([externalId, platform])
  @@index([competitorId])
}

// ============ SOCIAL API TOKENS ============

model SocialToken {
  id             String    @id @default(cuid())
  platform       Platform
  tokenType      String    @default("page")  // "page", "user", "api_key"

  // For brand/platform tokens (Meta Page tokens, YouTube API keys)
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // For influencer tokens (YouTube Analytics OAuth)
  influencerId   String?
  influencer     Influencer? @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  // Token data (encrypted AES-256-GCM)
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?
  scopes         String[]

  // Platform-specific IDs
  platformUserId String?   // Meta: IG User ID, YouTube: Channel ID
  platformPageId String?   // Meta: Facebook Page ID

  isValid        Boolean   @default(true)
  lastUsedAt     DateTime?
  lastError      String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([platform, userId, tokenType])
  @@index([influencerId])
  @@map("social_tokens")
}
